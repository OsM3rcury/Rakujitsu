        [
            "Marvis.exe",
            "Marvis"
        ]
    ],
    "checkver": {
        "script": [
            "$redirectUrl = curl.exe -sI -o NUL -w '%{redirect_url}' \"https://marvis.qq.com/download/exe\"",
            "$version = [regex]::Match($redirectUrl, 'marvis_\\d+_([\\d.]+)_').Groups[1].Value",
            "Write-Output $version"
        ]
    },
