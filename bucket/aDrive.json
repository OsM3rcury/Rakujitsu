{
    "homepage": "https://www.alipan.com/",
    "description": "阿里云盘桌面客户端 - 备份无忧 整理有序",
    "version": "6.9.1",
    "license": {
        "identifier": "EULA"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn.aliyundrive.net/downloads/apps/desktop/aDrive-6.9.1.exe",
            "hash": "cc40289de6c35821214c816b8a1101c3ada822f05c7da3b770ae432067eea76a"
        }
    },
    "innosetup": true,
    "installer": {
        "script": [
            "if (!(Test-Path $persist_dir)) { New-Item $persist_dir -Type Directory -Force | Out-Null }",
            "$runtimeAppdata = \"$env:APPDATA\\aDrive\"",
            "$runtimePersist = \"$persist_dir\\aDrive\\appdata\"",
            "if (Test-Path $runtimePersist) {",
            "    Remove-Item $runtimeAppdata -Force -Recurse -ErrorAction SilentlyContinue",
            "    New-Item -Type Junction -Path $runtimeAppdata -Target $runtimePersist | Out-Null",
            "} else {",
            "    if (Test-Path $runtimeAppdata) {",
            "        Move-Item $runtimeAppdata $runtimePersist -Force",
            "        New-Item -Type Junction -Path $runtimeAppdata -Target $runtimePersist | Out-Null",
            "    }",
            "}"
        ]
    },
    "uninstaller": {
        "script": [
            "$runtimeAppdata = \"$env:APPDATA\\aDrive\"",
            "$runtimePersist = \"$persist_dir\\aDrive\\appdata\"",
            "if (!(Test-Path $runtimePersist)) {",
            "    Move-Item $runtimeAppdata $runtimePersist -Force",
            "} else {",
            "    Remove-Item $runtimeAppdata -Force -Recurse -ErrorAction SilentlyContinue",
            "}"
        ]
    },
    "bin": "aDrive.exe",
    "shortcuts": [
        [
            "aDrive.exe",
            "阿里云盘"
        ]
    ],
    "checkver": {
        "url": "https://www.aliyundrive.com/desktop/version/update.json",
        "jsonpath": "$.url",
        "regex": "aliyun-drive-desktop-version/([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.aliyundrive.net/downloads/apps/desktop/aDrive-$version.exe"
            }
        }
    }
}
