            "hash": "b38e0448c75451c7f52799153197120a88322a09b080db1489e7917d73bf8ae9"
        }
    },
    "installer": {
        "script": [
            "Get-ChildItem \"$dir\\redist_packages\" | Move-Item -Destination \"$dir\" -Force",
            "$persistAppdata = \"$persist_dir\\appdata\"",
            "$runtimeAppdata = \"$env:LOCALAPPDATA\\Netease\\CloudMusic\"",
            "if (!(Test-Path $persistAppdata)) { New-Item $persistAppdata -Type Directory -Force | Out-Null }",
            "if (Test-Path $runtimeAppdata) {",
            "    if ((Get-Item $runtimeAppdata -Force).LinkType -ne 'Junction') {",
            "        Copy-Item $runtimeAppdata $persistAppdata -Recurse -Force -ErrorAction SilentlyContinue",
            "        Remove-Item $runtimeAppdata -Recurse -Force",
            "    }",
            "}",
            "if (!(Test-Path $runtimeAppdata)) { New-Item -Type Junction -Path $runtimeAppdata -Target $persistAppdata | Out-Null }"
        ]
    },
    "post_install": "Remove-Item \"$dir\\`$PLUGINSDIR\",\"$dir\\redist_packages\" -Force -Recurse",
    "uninstaller": {
        "script": [
            "$runtimeAppdata = \"$env:LOCALAPPDATA\\Netease\\CloudMusic\"",
            "if ((Get-Item $runtimeAppdata -Force).LinkType -eq 'Junction') { Remove-Item $runtimeAppdata -Force }"
        ]
    },
    "bin": "cloudmusic.exe",
    "shortcuts": [
        [
            "cloudmusic.exe",
            "网易云音乐"
        ]
    ],
    "checkver": {
        "url": "https://music.163.com/api/appcustomconfig/get",
        "jsonpath": "$.data.web-new-download.pc64.downloadUrl",
        "regex": "NeteaseCloudMusic_Music_official_([\\d.]+)_64.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_$version_64.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://d8.music.126.net/dmusic2/NeteaseCloudMusic_Music_official_$version_32.exe#/dl.7z"
            }
        }
    }
}